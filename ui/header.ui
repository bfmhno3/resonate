      <string notr="true">QLineEdit {
    background-color: rgba(0, 0, 0, 0.05);
    border: none;
    border-radius: 14px; /* 高度 28 的一半，实现完美半圆角 */
    padding-left: 15px; /* 文字左侧留白，如果后续要加放大镜图标，这里设为 0 */
}
